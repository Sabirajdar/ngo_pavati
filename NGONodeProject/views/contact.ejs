<!DOCTYPE html>
<html>
<head>
<title>Contact Maintenance</title>

<style>

/* CONTACT PAGE WRAPPER */

.contact-wrapper{
font-family: Arial, sans-serif;
background:#f4f6f9;
padding:10px 0;
}

/* PANEL */

.contact-wrapper .panel{
background:#ffffff;
width:95%;
max-width:1400px;
margin:20px auto;
padding:25px;
border-radius:10px;
box-shadow:0 4px 15px rgba(0,0,0,0.08);
}

/* HEADING */

.contact-wrapper h2{
text-align:center;
color:#1e293b;
margin-bottom:20px;
}

/* FORM GRID */

.contact-wrapper .form-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px 25px;
}

/* FORM GROUP */

.contact-wrapper .form-group{
display:flex;
flex-direction:column;
}

/* LABEL */

.contact-wrapper label{
font-weight:600;
margin-bottom:5px;
color:#334155;
}

/* INPUTS */

.contact-wrapper input,
.contact-wrapper textarea{
padding:10px;
border:1px solid #cbd5e1;
border-radius:6px;
font-size:14px;
width:100%;
}

/* TEXTAREA */

.contact-wrapper textarea{
height:80px;
resize:none;
}

/* BUTTON POSITION */

.contact-wrapper .button-row{
grid-column:1;
margin-top:5px;
}

/* BUTTON */

.contact-wrapper button{
padding:10px 20px;
background:#2563eb;
color:#fff;
border:none;
border-radius:6px;
cursor:pointer;
font-weight:600;
width:120px;
}

.contact-wrapper button:hover{
background:#1d4ed8;
}

/* TABLE */

.contact-wrapper table{
width:100%;
border-collapse:collapse;
margin-top:20px;
}

.contact-wrapper th,
.contact-wrapper td{
border:1px solid #e2e8f0;
padding:10px;
text-align:center;
}

.contact-wrapper th{
background:#e2e8f0;
color:#1e293b;
}

/* TABLE ROW HOVER */

.contact-wrapper tbody tr:hover{
background:#f1f5f9;
}

/* LINKS */

.contact-wrapper a{
text-decoration:none;
}
</style>

</head>

<body>

<div class="contact-wrapper">

<div class="panel">

<h2><%= editData ? "Update Contact" : "Add Contact" %></h2>

<form action="<%= editData ? '/update-contact/' + editData.CONT_US_ID : '/add-contact' %>" method="POST">

<div class="form-grid">

<div class="form-group">
<label>Primary Mobile</label>
<input type="text" name="pri_mobile"
value="<%= editData ? editData.PRI_MOBILE : '' %>" required>
</div>

<div class="form-group">
<label>Alternate Mobile</label>
<input type="text" name="alt_mobile"
value="<%= editData ? editData.ALT_MOBILE : '' %>">
</div>

<div class="form-group">
<label>Email</label>
<input type="email" name="email"
value="<%= editData ? editData.EMAIL : '' %>">
</div>

<div class="form-group">
<label>Message</label>
<textarea name="message"><%= editData ? editData.MESSAGE : '' %></textarea>
</div>

<div class="button-row">
<button type="submit">
<%= editData ? "Update" : "Save" %>
</button>
</div>

</div>

</form>

</div>

<div class="panel">

<h2>Contact Records</h2>

<table>

<tr>
<th>ID</th>
<th>Primary</th>
<th>Alternate</th>
<th>Email</th>
<th>Message</th>
<th>Created</th>
<th>Action</th>
</tr>

<% contactData.forEach(function(contact){ %>

<tr>

<td><%= contact.CONT_US_ID %></td>
<td><%= contact.PRI_MOBILE %></td>
<td><%= contact.ALT_MOBILE %></td>
<td><%= contact.EMAIL %></td>
<td><%= contact.MESSAGE %></td>
<td><%= contact.CREATED_AT %></td>

<td>
<a href="/contact/<%= contact.CONT_US_ID %>">
<button>Edit</button>
</a>
</td>

</tr>

<% }) %>

</table>

</div>

</div>

</body>
</html>