<%- include('partials/header') %>

<div class="container mt-4">

<div class="d-flex justify-content-between align-items-center mb-4">
<h3 class="fw-bold">
<i class="bi bi-person-circle"></i> NGO Member Profile
</h3>
</div>

<div class="row">

<!-- Contact Details -->
<div class="col-md-6">
<div class="card shadow-sm mb-4 border-0">

<div class="card-header card-header-custom">
<i class="bi bi-telephone-fill"></i> Contact Details
</div>

<div class="card-body">
<table class="table table-borderless">

<tr>
<th>Primary Mobile</th>
<td><%= data.PRI_MOBILE || "-" %></td>
</tr>

<tr>
<th>Alternate Mobile</th>
<td><%= data.ALT_MOBILE || "-" %></td>
</tr>

<tr>
<th>Landline</th>
<td><%= data.LANDLINE_NUMBER || "-" %></td>
</tr>

<tr>
<th>Email</th>
<td><%= data.EMAIL || "-" %></td>
</tr>

<tr>
<th>Website</th>
<td><%= data.WEBSITE || "-" %></td>
</tr>

</table>
</div>
</div>
</div>

<!-- Member Details -->
<div class="col-md-6">
<div class="card shadow-sm mb-4 border-0">

<div class="card-header card-header-custom">
<i class="bi bi-person-fill"></i> Member Details
</div>

<div class="card-body">
<table class="table table-borderless">

<tr>
<th>Full Name</th>
<td><%= data.FULL_NAME || "-" %></td>
</tr>

<tr>
<th>PAN Number</th>
<td><%= data.PAN_NUMBER || "-" %></td>
</tr>

<tr>
<th>Aadhaar</th>
<td><%= data.AADHAR_NUMBER || "-" %></td>
</tr>

</table>
</div>
</div>
</div>

</div>

<div class="row">

<!-- Organization -->
<div class="col-md-6">
<div class="card shadow-sm mb-4 border-0">

<div class="card-header card-header-custom">
<i class="bi bi-building"></i> Organization Details
</div>

<div class="card-body">
<table class="table table-borderless">

<tr>
<th>Organization Name</th>
<td><%= data.ORG_NAME || "-" %></td>
</tr>

<tr>
<th>Registration No</th>
<td><%= data.ORG_REG_NUMBER || "-" %></td>
</tr>

<tr>
<th>Registration Date</th>
<td><%= data.ORG_REG_DATE || "-" %></td>
</tr>

<tr>
<th>80G Registration</th>
<td><%= data.ORG_80G_REG_NUMBER || "-" %></td>
</tr>

<tr>
<th>80G Date</th>
<td><%= data.ORG_80G_REG_DATE || "-" %></td>
</tr>

<tr>
<th>12A Registration</th>
<td><%= data.ORG_12A_REG_NUMBER || "-" %></td>
</tr>

<tr>
<th>12A Date</th>
<td><%= data.ORG_12A_REG_DATE || "-" %></td>
</tr>

</table>
</div>
</div>
</div>

<!-- Membership -->
<div class="col-md-6">
<div class="card shadow-sm mb-4 border-0">

<div class="card-header card-header-custom">
<i class="bi bi-card-checklist"></i> Membership Details
</div>

<div class="card-body">
<table class="table table-borderless">

<tr>
<th>Membership ID</th>
<td><%= data.MEMBERSHIP_ID || "-" %></td>
</tr>

<tr>
<th>Start Date</th>
<td><%= data.START_DATE || "-" %></td>
</tr>

<tr>
<th>End Date</th>
<td><%= data.END_DATE || "-" %></td>
</tr>

<tr>
<th>Status</th>
<td>
<span class="badge bg-success px-3 py-2">
<%= data.MEMBERSHIP_STATUS || "-" %>
</span>
</td>
</tr>

</table>
</div>
</div>
</div>

</div>

</div>

<%- include('partials/footer') %>