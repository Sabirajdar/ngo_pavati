<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Reset Password</title>
    <style>
        .error-message {
            color: red;
            font-size: 14px;
            margin-top: -15px;
            margin-bottom: 15px;
        }
        .form-row {
            margin-bottom: 15px;
        }
        input:invalid {
            border-color: red;
        }
    </style>
</head>
<body>

<div class="login-container">

    <h2 class="page-title">Reset Password</h2>

    <form id="resetForm" action="/reset-password" method="post">

        <div class="form-row">
            <label>New Password</label>
            <input type="password" id="newPassword" name="newPassword" required>
            <div id="newError" class="error-message"></div>
        </div>

        <div class="form-row">
            <label>Confirm Password</label>
            <input type="password" id="confirmPassword" name="confirmPassword" required>
            <div id="confirmError" class="error-message"></div>
        </div>

        <!-- Server-side message -->
        <% if (typeof message !== 'undefined') { %>
            <div class="error-message"><%= message %></div>
        <% } %>

        <div class="button-group">
            <button type="submit">Reset</button>
            <button type="button" onclick="goBack()">Back</button>
        </div>

    </form>
</div>

<script>
document.getElementById("resetForm").addEventListener("submit", function(e) {
    let newPass = document.getElementById("newPassword").value.trim();
    let confirmPass = document.getElementById("confirmPassword").value.trim();
    let newError = document.getElementById("newError");
    let confirmError = document.getElementById("confirmError");

    // Reset errors
    newError.innerText = "";
    confirmError.innerText = "";

    let valid = true;

    // Check if fields are empty
    if (!newPass) {
        newError.innerText = "This field is required";
        valid = false;
    }

    if (!confirmPass) {
        confirmError.innerText = "This field is required";
        valid = false;
    }

    // Check if passwords match
    if (newPass && confirmPass && newPass !== confirmPass) {
        confirmError.innerText = "Passwords do not match!";
        valid = false;
    }

    if (!valid) {
        e.preventDefault(); // stop form submission
    }
});

function goBack() {
    window.location.href = "/";
}
</script>

</body>
</html>